{
  "name": "videofetch-webext",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:chrome",
    "typecheck": "tsc --noEmit",
    "build:chrome": "bun run typecheck && VIDEOFETCH_WEBEXT_TARGET=chrome vite build",
    "build:firefox": "bun run typecheck && VIDEOFETCH_WEBEXT_TARGET=firefox vite build",
    "lint:firefox": "bun run build:firefox && addons-linter --enable-data-collection-permissions --disable-linter-rules=no-unsanitized/property dist/firefox",
    "sign:firefox": "bash scripts/sign-firefox.sh",
    "run:firefox": "bun run build:firefox && web-ext run --source-dir dist/firefox",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.12",
    "addons-linter": "^7.20.0",
    "@types/chrome": "^0.1.17",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.8.2",
    "vite": "^7.1.3",
    "web-ext": "^8.9.0"
  }
}
