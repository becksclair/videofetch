{
  "manifest_version": 3,
  "name": "VideoFetch Sidebar",
  "description": "Control VideoFetch downloads with realtime progress, pause/resume/cancel, and native play.",
  "version": "0.1.0",
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "VideoFetch"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "commands": {
    "videofetch_open_sidepanel": {
      "suggested_key": {
        "default": "Alt+Z",
        "mac": "Alt+Z"
      },
      "description": "Open VideoFetch sidebar"
    },
    "videofetch_enqueue_current_page": {
      "suggested_key": {
        "default": "Alt+X",
        "mac": "Alt+X"
      },
      "description": "Enqueue current page URL"
    }
  },
  "sidebar_action": {
    "default_title": "VideoFetch",
    "default_panel": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "notifications",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "videofetch@local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
